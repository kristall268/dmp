
root = true

# ────────────────────────────────────────
#  All files
# ────────────────────────────────────────
[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true

# ────────────────────────────────────────
#  Java
# ────────────────────────────────────────
[*.java]
indent_style = space
indent_size  = 4
max_line_length = 120

# ────────────────────────────────────────
#  C / C++
# ────────────────────────────────────────
[*.{c,h,cpp,hpp,cc,cxx}]
indent_style = space
indent_size  = 2
max_line_length = 100

# ────────────────────────────────────────
#  CMake
# ────────────────────────────────────────
[CMakeLists.txt]
indent_style = space
indent_size  = 2

[*.cmake]
indent_style = space
indent_size  = 2

# ────────────────────────────────────────
#  Maven
# ────────────────────────────────────────
[pom.xml]
indent_style = space
indent_size  = 4

# ────────────────────────────────────────
#  Web / Config
# ────────────────────────────────────────
[*.{json,yaml,yml,xml}]
indent_style = space
indent_size  = 2

[*.css]
indent_style = space
indent_size  = 2

# ────────────────────────────────────────
#  Shell scripts
# ────────────────────────────────────────
[*.{sh,bash}]
indent_style = space
indent_size  = 2
end_of_line  = lf

# ────────────────────────────────────────
#  Windows batch
# ────────────────────────────────────────
[*.{cmd,bat}]
end_of_line  = crlf

# ────────────────────────────────────────
#  Markdown
# ────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false